# Airwallex FYI environment reference.
# Do not commit real .env files or real provider credentials.

# Database. The default H2 URL is for local development only.
DATABASE_URL=jdbc:h2:mem:airwallex_fyi;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;DEFAULT_NULL_ORDERING=HIGH
DATABASE_USERNAME=sa
DATABASE_PASSWORD=
DATABASE_DRIVER=org.h2.Driver

# Cloud Postgres example. Uncomment and fill these when moving off local H2.
# DATABASE_URL=jdbc:postgresql://HOST:5432/postgres?sslmode=require
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=
# DATABASE_DRIVER=org.postgresql.Driver

# AI summaries.
AI_PROVIDER=gemini
AI_MODEL=gemini-3.5-flash
GEMINI_API_KEY=

# Twilio WhatsApp Sandbox. Values should use the whatsapp:+... address format.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
WHATSAPP_TO=

# Digest and runtime behavior.
DIGEST_TIME_ZONE=Australia/Sydney
SCHEDULER_ENABLED=false
SCHEDULER_FIXED_DELAY=300000
AIRWALLEX_SITEMAP_URL=https://www.airwallex.com/global/sitemap-blog.xml
FIRST_RUN_SEED_LIMIT=25
DRY_RUN=true
ADMIN_TOKEN=dev-admin-token
